# CORS — comma-separated origins, or * to allow all (dev only)
ALLOWED_ORIGINS=http://localhost:5173,https://cerbro.vercel.app

# MongoDB
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB=cerbro

# Firebase Admin — paste the full service account JSON as a single line, OR provide a file path
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
# FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# Certificate signing
CERT_SECRET_KEY=your-hmac-secret-key
CERT_KEY_ID=K1
CERT_ID_PREFIX=GC2026
CERT_VERIFY_BASE_URL=https://cerbro.vercel.app/verify
